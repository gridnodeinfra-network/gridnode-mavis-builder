{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "brand": {
      "cyan":   { "$value": "#00e5ff", "$type": "color" },
      "green":  { "$value": "#05ffa1", "$type": "color" },
      "magenta":{ "$value": "#ff2a6d", "$type": "color" },
      "amber":  { "$value": "#ffd700", "$type": "color" },
      "orange-u100": { "$value": "#ff8200", "$type": "color", "$comment": "ISO/BD strength cue for U-100 vials" }
    },
    "bg": {
      "void":     { "$value": "#020208", "$type": "color" },
      "panel":    { "$value": "#0a0a14", "$type": "color" },
      "raised":   { "$value": "#1e1e2e", "$type": "color" }
    },
    "text": {
      "bright": { "$value": "#e7fbff", "$type": "color" },
      "mid":    { "$value": "#c0c5d0", "$type": "color" },
      "dim":    { "$value": "#6a7080", "$type": "color" },
      "faint":  { "$value": "#4a5060", "$type": "color" },
      "ghost":  { "$value": "#3a4050", "$type": "color" }
    }
  },
  "font": {
    "family": {
      "mono":    { "$value": "'SF Mono', 'Monaco', 'Consolas', monospace", "$type": "fontFamily" },
      "display": { "$value": "'SF Mono', 'Monaco', 'Consolas', monospace", "$type": "fontFamily" }
    },
    "size": {
      "xs": { "$value": "0.5rem",  "$type": "dimension" },
      "sm": { "$value": "0.62rem", "$type": "dimension" },
      "md": { "$value": "0.78rem", "$type": "dimension" },
      "lg": { "$value": "1rem",    "$type": "dimension" },
      "xl": { "$value": "1.4rem",  "$type": "dimension" },
      "2xl":{ "$value": "2.2rem",  "$type": "dimension" },
      "3xl":{ "$value": "3.6rem",  "$type": "dimension" },
      "4xl":{ "$value": "5.5rem",  "$type": "dimension" },
      "hero":{ "$value": "7rem",    "$type": "dimension", "$comment": "Hero monument. Don't use anywhere else." }
    },
    "weight": {
      "light":   { "$value": "100", "$type": "fontWeight" },
      "regular": { "$value": "300", "$type": "fontWeight" },
      "medium":  { "$value": "500", "$type": "fontWeight" },
      "bold":    { "$value": "700", "$type": "fontWeight" }
    },
    "letter-spacing": {
      "tight":  { "$value": "-3px", "$type": "dimension" },
      "normal": { "$value": "0",    "$type": "dimension" },
      "wide":   { "$value": "2px",  "$type": "dimension" },
      "label":  { "$value": "3px",  "$type": "dimension" }
    }
  },
  "space": {
    "1":  { "$value": "4px",  "$type": "dimension" },
    "2":  { "$value": "8px",  "$type": "dimension" },
    "3":  { "$value": "12px", "$type": "dimension" },
    "4":  { "$value": "16px", "$type": "dimension" },
    "5":  { "$value": "20px", "$type": "dimension" },
    "6":  { "$value": "24px", "$type": "dimension" },
    "8":  { "$value": "32px", "$type": "dimension" },
    "10": { "$value": "40px", "$type": "dimension" }
  },
  "border": {
    "radius": {
      "sm":  { "$value": "4px",  "$type": "dimension" },
      "md":  { "$value": "8px",  "$type": "dimension" },
      "lg":  { "$value": "14px", "$type": "dimension" },
      "pill": { "$value": "999px", "$type": "dimension" }
    },
    "width": {
      "thin":  { "$value": "1px",   "$type": "dimension" },
      "thick": { "$value": "1.5px", "$type": "dimension" }
    }
  },
  "shadow": {
    "glow-cyan":   { "$value": "0 0 24px rgba(0,229,255,0.5)",  "$type": "shadow" },
    "glow-magenta": { "$value": "0 0 8px rgba(255,42,109,0.9)",  "$type": "shadow" },
    "glow-green":   { "$value": "0 0 12px rgba(5,255,161,0.5)",  "$type": "shadow" },
    "panel":        { "$value": "0 0 32px rgba(0,0,0,0.5), inset 0 0 24px rgba(0,229,255,0.02)", "$type": "shadow" }
  },
  "animation": {
    "duration": {
      "fast":   { "$value": "200ms", "$type": "duration" },
      "medium": { "$value": "600ms", "$type": "duration" },
      "slow":   { "$value": "2s",    "$type": "duration" }
    },
    "easing": {
      "snap":   { "$value": "cubic-bezier(0.16, 1, 0.3, 1)",   "$type": "cubicBezier" },
      "spring": { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier" },
      "linear": { "$value": "linear",                            "$type": "cubicBezier" }
    }
  },
  "opacity": {
    "faint":  { "$value": "0.3", "$type": "number" },
    "ghost":  { "$value": "0.5", "$type": "number" },
    "muted":  { "$value": "0.7", "$type": "number" },
    "full":   { "$value": "1.0", "$type": "number" }
  }
}
